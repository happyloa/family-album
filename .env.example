# ── 必填 ──
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=family-album
R2_PUBLIC_BASE=https://<bucket>.<account>.r2.cloudflarestorage.com
ADMIN_ACCESS_TOKEN=your_admin_password

# ── 選用（皆有預設值，可不填）──
# 密碼錯誤次數上限（預設 5 次 / 5 分鐘）
# ADMIN_RATE_LIMIT_MAX_FAILURES=5
# 圖片單檔上限 MB（預設 10）；NEXT_PUBLIC_ 版本供前端驗證顯示
# MAX_IMAGE_SIZE_MB=10
# NEXT_PUBLIC_MAX_IMAGE_SIZE_MB=10
# 影片單檔上限 MB（預設 150）
# MAX_VIDEO_SIZE_MB=150
# NEXT_PUBLIC_MAX_VIDEO_SIZE_MB=150
